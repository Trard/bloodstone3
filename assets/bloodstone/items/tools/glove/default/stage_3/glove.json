{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": [
          "firstperson_lefthand",
          "thirdperson_lefthand"
        ],
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:using_item",
          "on_false": {
            "type": "minecraft:model",
            "model": "bloodstone:item/tools/glove/default/left/stage_3/normal/glove"
          },
          "on_true": {
            "type": "minecraft:model",
            "model": "bloodstone:item/tools/glove/default/left/stage_3/blocking/glove"
          }
        }
      },
      {
        "when": [
          "firstperson_righthand",
          "thirdperson_righthand"
        ],
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:using_item",
          "on_false": {
            "type": "minecraft:model",
            "model": "bloodstone:item/tools/glove/default/right/stage_3/normal/glove"
          },
          "on_true": {
            "type": "minecraft:model",
            "model": "bloodstone:item/tools/glove/default/right/stage_3/blocking/glove"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:using_item",
      "on_false": {
        "type": "minecraft:model",
        "model": "bloodstone:item/tools/glove/default/right/stage_3/normal/glove"
      },
      "on_true": {
        "type": "minecraft:model",
        "model": "bloodstone:item/tools/glove/default/right/stage_3/blocking/glove"
      }
    }
  }
}
